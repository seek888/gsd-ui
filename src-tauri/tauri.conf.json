{
  "$schema": "https://v2.tauri.app/schemas/desktop.schema.json",
  "productName": "GSD UI",
  "version": "0.1.0",
  "identifier": "com.gsd.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GSD UI",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Developer Tool",
    "shortDescription": "A desktop interface for the GSD workflow",
    "longDescription": "GSD UI provides a visual interface for the GSD (Get Shit Done) workflow, allowing developers to manage projects, execute commands, and edit planning documents.",
    "publisher": "gsd-ui"
  }
}
