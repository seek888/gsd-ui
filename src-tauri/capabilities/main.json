{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:event:default",
    "core:window:default",
    "core:app:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        { "name": "cargo", "cmd": "cargo", "args": true },
        { "name": "pnpm", "cmd": "pnpm", "args": true },
        { "name": "yarn", "cmd": "yarn", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true },
        { "name": "sh", "cmd": "sh", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        { "name": "cargo", "cmd": "cargo", "args": true },
        { "name": "pnpm", "cmd": "pnpm", "args": true },
        { "name": "yarn", "cmd": "yarn", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true },
        { "name": "sh", "cmd": "sh", "args": true }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-watch",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-copy-file",
    "fs:allow-remove",
    "fs:allow-rename",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPLOCALDATA/**" }
      ]
    },
    "store:default",
    "dialog:allow-open",
    "dialog:allow-message"
  ]
}
